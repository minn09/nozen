{
	"name": "nozen",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@11.8.0",
	"lint-staged": {
		"*.{ts,tsx}": [
			"pnpm check"
		]
	},
	"scripts": {
		"build": "next build",
		"dev": "next dev",
		"lint": "node node_modules/@biomejs/biome/bin/biome lint .",
		"format": "node node_modules/@biomejs/biome/bin/biome format --write .",
		"check": "node node_modules/@biomejs/biome/bin/biome check --write .",
		"start": "next start",
		"prepare": "husky",
		"dev:tauri": "BUILD_FOR_TAURI=true next dev -H 127.0.0.1",
		"build:tauri": "BUILD_FOR_TAURI=true next build",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "1.1.4",
		"@radix-ui/react-dropdown-menu": "2.1.4",
		"@radix-ui/react-label": "2.1.1",
		"@radix-ui/react-separator": "1.1.1",
		"@radix-ui/react-slot": "1.2.4",
		"@vercel/analytics": "1.3.1",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"date-fns": "4.4.0",
		"framer-motion": "12.23.26",
		"lucide-react": "0.454.0",
		"next": "16.0.10",
		"next-themes": "0.4.6",
		"radix-ui": "1.6.0",
		"react": "19.2.0",
		"react-day-picker": "10.0.1",
		"react-dom": "19.2.0",
		"sonner": "2.0.7",
		"zustand": "5.0.11",
		"tailwind-merge": "3.3.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@tailwindcss/postcss": "4.1.9",
		"@types/node": "22.15.3",
		"@types/react": "19.2.0",
		"@types/react-dom": "19.2.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"postcss": "8.5.6",
		"tailwindcss": "4.1.9",
		"tw-animate-css": "1.3.3",
		"@tauri-apps/cli": "^2",
		"typescript": "5.9.3"
	}
}
